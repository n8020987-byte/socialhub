function saveRecord(gameKey, score) {
  const currentUser = localStorage.getItem("currentUser");
  if (!currentUser) return;
  
  database.ref(`leaderboards/${gameKey}/${currentUser}`).once('value').then((snapshot) => {
    const oldScore = snapshot.val() || 0;
    if (score > oldScore) {
      database.ref(`leaderboards/${gameKey}/${currentUser}`).set(score, () => {
        if(sidebarMode === "profile") updateProfileDOM(); // На лету обновляем паспорт
      });
    }
  });
}

function loadLeaderboard() {
  database.ref(`leaderboards/${leaderboardGame}`).orderByValue().limitToLast(10).on("value", (snapshot) => {
    if (sidebarMode !== "scores") return;
    
    const scores = [];
    snapshot.forEach((child) => {
      scores.push({ name: child.key, score: child.val() });
    });
    scores.reverse();

    if (scores.length === 0) {
      leaderboardList.innerHTML = `<li>Никто ещё не играл</li>`;
    } else {
      leaderboardList.innerHTML = scores.map((s, index) => 
        `<li>🏆 ${index + 1}. <strong>${s.name}</strong>: ${s.score}</li>`
      ).join("");
    }
  });
}


// ТЕТРИС
function drawTetris() {
  for (let r = 0; r < T_ROWS; r++) {
    for (let c = 0; c < T_COLS; c++) {
      const cell = document.getElementById(`tc-${r}-${c}`);
      if (cell) cell.className = 't-cell' + (tBoard[r][c] ? ' t-filled' : '');
    }
  }
  if (curPiece) {
    for (let r = 0; r < curPiece.length; r++) {
      for (let c = 0; c < curPiece[r].length; c++) {
        if (curPiece[r][c] && curY + r >= 0) {
          const cell = document.getElementById(`tc-${curY + r}-${curX + c}`);
          if (cell) cell.className = 't-cell t-filled';
        }
      }
    }
  }
}

function collision(px, py, piece) {
  for (let r = 0; r < piece.length; r++) {
    for (let c = 0; c < piece[r].length; c++) {
      if (piece[r][c]) {
        let nx = px + c, ny = py + r;
        if (nx < 0 || nx >= T_COLS || ny >= T_ROWS) return true;
        if (ny >= 0 && tBoard[ny][nx]) return true;
      }
    }
  }
  return false;
}

function mergePiece() {
  for (let r = 0; r < curPiece.length; r++) {
    for (let c = 0; c < curPiece[r].length; c++) {
      if (curPiece[r][c] && curY + r >= 0) tBoard[curY + r][curX + c] = 1;
    }
  }
  for (let r = T_ROWS - 1; r >= 0; r--) {
    if (tBoard[r].every(v => v === 1)) {
      tBoard.splice(r, 1);
      tBoard.unshift(Array(T_COLS).fill(0));
      tetrisScore += 10; 
      document.getElementById("tetris-score-val").textContent = tetrisScore;
      saveRecord("tetris", tetrisScore); 
      r++;
    }
  }
}

function spawnPiece() {
  curPiece = SHAPES[Math.floor(Math.random() * SHAPES.length)];
  curX = Math.floor((T_COLS - curPiece[0].length) / 2);
  curY = -curPiece.length;
  if (collision(curX, 0, curPiece)) {
    tBoard = Array(T_ROWS).fill().map(() => Array(T_COLS).fill(0));
    tetrisScore = 0; 
    document.getElementById("tetris-score-val").textContent = tetrisScore;
  }
}

window.controlTet = (action) => {
  if (!curPiece) return;
  if (action === 'L' && !collision(curX - 1, curY, curPiece)) curX--;
  if (action === 'R' && !collision(curX + 1, curY, curPiece)) curX++;
  if (action === 'D' && !collision(curX, curY + 1, curPiece)) curY++;
  if (action === 'U') {
    let rotated = curPiece[0].map((_, i) => curPiece.map(row => row[i]).reverse());
    if (!collision(curX, curY, rotated)) curPiece = rotated;
  }
  drawTetris();
};

function runTetris() {
  if (!curPiece) return;
  if (collision(curX, curY + 1, curPiece)) {
    mergePiece();
    spawnPiece();
  } else {
    curY++;
  }
  drawTetris();
}

function startTetrisLoop() {
  clearInterval(tetrisInterval);
  const currentSpeed = isTurboSpeed ? 180 : 400; 
  tetrisInterval = setInterval(runTetris, currentSpeed);
}


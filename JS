// ЭКРАН ЧАТА И ПОМОЩНИКА
function renderAIChat() {
  let titleText = "Gemini 2.5 Flash Ассистент";
  if (chatMode === "private") titleText = `🔒 Личный чат с: ${privateTarget}`;

  content.innerHTML = `
    <section class="ai-screen">
      <h2>${titleText}</h2>
      <div class="game-picker" style="margin-bottom:12px; gap: 5px; flex-wrap: wrap;">
        <button class="game-card ${chatMode === "gemini" ? "active" : ""}" id="btn-mode-gemini">Gemini (ИИ)</button>
        ${chatMode === "private" ? `<button class="game-card active" id="btn-back-global" style="background:#ff3d3d; color:white;">⬅ Назад к Gemini</button>` : ""}
      </div>
      <div class="ai-area">
        <div class="chat-history" id="chat-history"></div>
        <div class="chat-input-wrap">
          <input type="text" id="chat-input" class="chat-input" placeholder="Введите сообщение...">
          <button class="btn btn-send" id="btn-send-chat">></button>
        </div>
      </div>
    </section>
  `;

  const input = document.getElementById("chat-input");
  const sendBtn = document.getElementById("btn-send-chat");
  const history = document.getElementById("chat-history");

  document.getElementById("btn-mode-gemini").onclick = () => { chatMode = "gemini"; privateTarget = ""; renderAIChat(); };
  if (chatMode === "private") {
    document.getElementById("btn-back-global").onclick = () => { chatMode = "gemini"; privateTarget = ""; renderAIChat(); };
  }

  function addMessage(text, side, authorName = "") {
    const m = document.createElement("div");
    m.className = `msg ${side}`;
    m.textContent = authorName ? `${authorName}: ${text}` : text;
    history.appendChild(m);
    history.scrollTop = history.scrollHeight;
  }

  database.ref("private_messages").off();
  const currentUser = localStorage.getItem("currentUser") || "Гость";

  if (chatMode === "private") {
    const roomID = [currentUser, privateTarget].sort().join("-");
    database.ref("private_messages").child(roomID).limitToLast(50).on("child_added", (snapshot) => {
      const msgData = snapshot.val();
      const side = msgData.name === currentUser ? "user" : "bot";
      addMessage(msgData.text, side, msgData.name);
    });
  } else {
    addMessage("Привет! На связи обновлённый Gemini 2.5 Flash. Я готов решать задачи, писать код или просто болтать!", "bot");
  }

  sendBtn.onclick = async () => {
    const text = input.value.trim();
    if (!text) return;

    if (chatMode === "private") {
      const roomID = [currentUser, privateTarget].sort().join("-");
      database.ref("private_messages").child(roomID).push({
        name: currentUser,
        text: text,
        timestamp: Date.now()
      });
      input.value = "";
    } else {
      addMessage(text, "user");
      input.value = "";

      const loadingMsg = document.createElement("div");
      loadingMsg.className = "msg bot";
      loadingMsg.textContent = "Gemini 2.5 думает...";
      history.appendChild(loadingMsg);
      history.scrollTop = history.scrollHeight;

      try {
        const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${API_token}`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ contents: [{ parts: [{ text: text }] }] })
        });

        const data = await response.json();
        history.removeChild(loadingMsg);

        if (data.candidates && data.candidates[0].content.parts[0].text) {
          addMessage(data.candidates[0].content.parts[0].text, "bot");
        } else if (data.error) {
          addMessage(`Ошибка Gemini API: ${data.error.message}`, "bot");
        } else {
          addMessage("Ошибка получения ответа от Google.", "bot");
        }
      } catch (e) {
        if (history.contains(loadingMsg)) history.removeChild(loadingMsg);
        addMessage("Не удалось подключиться к ИИ.", "bot");
      }
    }
  };

  input.onkeydown = (e) => { if (e.key === "Enter") sendBtn.click(); };
}


      <p style="margin:0;">Очки: <span id="tetris-score-val" style="color:var(--accent); font-weight:bold;">${tetrisScore}</span></p>
      <div style="display:flex; gap:5px;">
        <button class="game-card ${isTurboSpeed ? 'active' : ''}" id="btn-tetris-turbo" style="padding:4px 8px; font-size:11px;">⚡ Скорость 2x</button>
        <button class="game-card" id="btn-tetris-clear" style="padding:4px 8px; font-size:11px; background:rgba(255,61,61,0.1); border-color:#ff3d3d; color:#ff3d3d;">🗑 Сбросить</button>
      </div>
    </div>
    <div class="tetris-wrap">
      <div class="tetris-grid">${gridHTML}</div>
      <div class="tetris-controls">
        <button class="btn-ctrl" onclick="controlTet('L')">◀</button>
        <button class="btn-ctrl" onclick="controlTet('U')">🔄</button>
        <button class="btn-ctrl" onclick="controlTet('D')">▼</button>
        <button class="btn-ctrl" onclick="controlTet('R')">▶</button>
      </div>
    </div>
  `;

  document.getElementById("btn-tetris-turbo").onclick = () => {
    isTurboSpeed = !isTurboSpeed;
    document.getElementById("btn-tetris-turbo").classList.toggle("active", isTurboSpeed);
    startTetrisLoop();
  };

  document.getElementById("btn-tetris-clear").onclick = () => {
    if(confirm("Очистить стакан и обнулить очки Тетриса?")) {
      tBoard = Array(T_ROWS).fill().map(() => Array(T_COLS).fill(0));
      tetrisScore = 0;
      document.getElementById("tetris-score-val").textContent = tetrisScore;
      saveRecord("tetris", 0);
      spawnPiece();
      drawTetris();
    }
  };

  if (!curPiece) spawnPiece();
  drawTetris();
  startTetrisLoop(); 
}

